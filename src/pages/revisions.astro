---
import { getCollection } from 'astro:content';
import Datasheet from '../layouts/Datasheet.astro';
import RevTable from '../components/RevTable.astro';

const releaseCount = (await getCollection('news')).filter((e) => e.data.kind === 'release').length;
---

<Datasheet
  title="Revision history — EduMIPS64"
  description="Every EduMIPS64 release since 1.0: dates, versions, codenames and release notes."
  docRef="REVISION HISTORY"
>
  <main class="wrap">
    <p class="kicker">5. Revision history</p>
    <h1>Revision history</h1>
    <p class="section-intro">All {releaseCount} EduMIPS64 releases, newest first. Downloads
    for the latest release are on
    <a href="https://github.com/EduMIPS64/edumips64/releases/latest">GitHub</a>.</p>
    <RevTable />
    <p class="backlink"><a href="/">← www.edumips.org</a></p>
  </main>
</Datasheet>

<style>
  main { padding-top: 56px; }
  h1 {
    font-family: var(--display); font-weight: 800;
    font-size: clamp(28px, 4vw, 40px); line-height: 1.1; letter-spacing: -.02em;
    margin-bottom: 24px;
  }
  .backlink { font-family: var(--mono); font-size: 13px; margin: 40px 0 0; }
</style>
